{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run inngest\"",
    "dev:next": "INNGEST_DEV=1 next dev",
    "dev:3001": "INNGEST_DEV=1 next dev -p 3001",
    "inngest": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:3000/api/inngest -u http://localhost:3001/api/inngest",
    "email": "email dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "node scripts/seed.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@arcjet/next": "^1.4.0",
    "@clerk/nextjs": "^6.39.5",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "inngest": "^4.5.0",
    "lucide-react": "^1.17.0",
    "next": "^15.1.7",
    "prisma": "^5.22.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "react-spinners": "^0.17.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.8.3",
    "sonner": "^2.0.7",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
